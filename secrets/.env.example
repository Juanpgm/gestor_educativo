# ══════════════════════════════════════════════════════════════
# Gestor Educativo — Environment Variables
# Copy this file into secrets/.env and fill in the values.
# NEVER commit secrets/.env to version control.
# ══════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────
APP_NAME="Gestor Educativo"
APP_VERSION="0.1.0"
BASE_URL=http://localhost:8000
DEBUG=true

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gestor_user:gestor_dev_password@localhost:5432/gestor_educativo

# ── Security ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_generate_a_random_64char_string
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_generate_fernet_key

# ── JWT Tokens ────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── LLM / OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME
LLM_MODEL=gpt-4o-mini

# ── Gmail API ─────────────────────────────────────────────────
GMAIL_CREDENTIALS_PATH=secrets/credentials/gmail_credentials.json
GMAIL_TOKEN_PATH=secrets/credentials/gmail_token.json

# ── File Paths ────────────────────────────────────────────────
TEMPLATES_DIR=templates
UPLOAD_DIR=uploads
GENERATED_DIR=generated
